@prefix hmktei: <urn:himiko:ontology:physical:tei:> .
@prefix hmkp:   <urn:himiko:ontology:physical:> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#################################################################
#    Ontology metadata
#################################################################

<urn:himiko:ontology:physical:tei> a owl:Ontology ;
    dcterms:title "HIMIKO Physical Layer — TEI Conversion Profile"@en ;
    dcterms:title "HIMIKO 史料物理層 — TEI 変換プロファイル"@ja ;
    dcterms:description """HIMIKO 史料物理層 (urn:himiko:ontology:physical) の付属プロファイル。
TEI/EDCS の要素・属性に由来する、アノテーションの細目プロパティを定義する。
これらは特定の入力フォーマット (TEI Guidelines) の語彙に対応するものであり、
史料種別に依存しない抽象的枠組みである物理層コアからは意図的に分離してある。
各プロパティは hmkp:Annotation を domain とし、対応する TEI の要素・属性を
rdfs:seeAlso で示す。値そのものは元 TEI の属性値をそのまま保持する。"""@ja ;
    dcterms:creator "HIMIKO project" ;
    owl:versionInfo "0.1.0" ;
    owl:imports <urn:himiko:ontology:physical> ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0> .

#################################################################
#    Classes  —  アノテーション種別 (hmkp:Annotation のサブクラス)
#################################################################
#
#  TEI の各要素に対応するアノテーション種別を、hmkp:Annotation の下位クラスとして
#  定義する。データ側では各アノテーションに `a hmkp:Annotation, hmktei:Gap` のように
#  コア型と種別型の双方を付与する (無推論エンドポイントでも両クエリが成立するため)。
#  移行期は互換のため hmktei:kind (文字列) も併記されるが、正準は本サブクラス階層。

hmktei:Line a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Line"@en , "行"@ja ;
    rdfs:comment "行の開始を示す構造マーカー (TEI <lb>)。テキストスパンではなく行頭位置を表し、hmktei:n に行番号を持つ。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#lb> .

hmktei:Expan a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Expansion"@en , "略語展開"@ja ;
    rdfs:comment "略号とその展開の全体 (TEI <expan>)。内側に略号形 (abbr) と補われた文字 (ex) を含む。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#expan> .

hmktei:Abbr a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Abbreviation"@en , "略号形"@ja ;
    rdfs:comment "実際に刻まれた略号形 (TEI <abbr>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#abbr> .

hmktei:Ex a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Expansion characters"@en , "補われた展開文字"@ja ;
    rdfs:comment "略号を展開する際に編者が補った文字 (TEI <ex>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#ex> .

hmktei:Supplied a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Supplied"@en , "補完"@ja ;
    rdfs:comment "原文で失われ編者が補った文字 (TEI <supplied>)。hmktei:reason に補完理由を持つ。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#supplied> .

hmktei:Gap a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Gap"@en , "欠損"@ja ;
    rdfs:comment "判読不能または失われた箇所 (TEI <gap>)。hmktei:reason / extent / quantity / unit を持ちうる。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#gap> .

hmktei:Choice a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Choice"@en , "訂正"@ja ;
    rdfs:comment "原文の読み (sic) と編者の訂正 (corr) の対 (TEI <choice>)。本文には corr を採り、元の読みを hmktei:sic に記録する。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#choice> .

hmktei:Surplus a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Surplus"@en , "余剰"@ja ;
    rdfs:comment "刻まれているが削除すべき余分な文字 (TEI <surplus>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#surplus> .

hmktei:Del a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Deletion"@en , "削除"@ja ;
    rdfs:comment "古代に削除された文字 (TEI <del>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#del> .

# 以下は書簡 (letter) TEI 由来の構造ブロック。EDCS 碑文には現れないが将来用に予約定義する。

hmktei:Seg a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Segment"@en , "セグメント"@ja ;
    rdfs:comment "任意の意味的・構造的テキスト区分 (TEI <seg>)。主に書簡で用いる。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#seg> .

hmktei:Opener a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Opener"@en , "冒頭部"@ja ;
    rdfs:comment "書簡の冒頭挨拶ブロック (TEI <opener>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#opener> .

hmktei:Closer a owl:Class ;
    rdfs:subClassOf hmkp:Annotation ;
    rdfs:label "Closer"@en , "結尾部"@ja ;
    rdfs:comment "書簡の結尾挨拶ブロック (TEI <closer>)。"@ja ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#closer> .

#################################################################
#    Datatype Properties  —  アノテーション種別 (互換用・移行期)
#################################################################

hmktei:kind a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "kind (TEI construct)"@en , "種別 (TEI 構成要素)"@ja ;
    rdfs:comment """[DEPRECATED — 移行期の互換用] アノテーションが由来する TEI の要素種別を
文字列で表す。正準の種別表現はサブクラス階層 (hmktei:Gap / Abbr / …) に移行済みであり、
このプロパティは既存クライアント互換のため各アノテーションに併記されるが、
全クライアントの型ベース移行完了後に廃止予定。取りうる値:
line, expan / abbr / ex, supplied, gap, choice, surplus, del,
seg / opener / closer。対応する下位クラスは同名 (先頭大文字) の hmktei: クラス。"""@ja ;
    owl:deprecated true ;
    rdfs:domain hmkp:Annotation ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0> .

#################################################################
#    Datatype Properties  —  TEI 属性由来の細目
#################################################################

hmktei:reason a owl:DatatypeProperty ;
    rdfs:label "reason"@en , "理由"@ja ;
    rdfs:comment "Gap / Supplied の @reason 属性値 (例: lost, unknown)。"@ja ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( hmktei:Gap hmktei:Supplied ) ] ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#att.editLike.reason> .

hmktei:extent a owl:DatatypeProperty ;
    rdfs:label "extent"@en , "範囲"@ja ;
    rdfs:comment "Gap の @extent 属性値 (例: unknown)。"@ja ;
    rdfs:domain hmktei:Gap ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#att.dimensions.extent> .

hmktei:quantity a owl:DatatypeProperty ;
    rdfs:label "quantity"@en , "数量"@ja ;
    rdfs:comment "Gap の @quantity 属性値 (欠損量)。"@ja ;
    rdfs:domain hmktei:Gap ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#att.dimensions.quantity> .

hmktei:unit a owl:DatatypeProperty ;
    rdfs:label "unit"@en , "単位"@ja ;
    rdfs:comment "Gap の @unit 属性値 (例: line, character)。"@ja ;
    rdfs:domain hmktei:Gap ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#att.dimensions.unit> .

hmktei:n a owl:DatatypeProperty ;
    rdfs:label "n"@en , "番号(n)"@ja ;
    rdfs:comment "TEI の @n 属性値。行番号 (hmktei:Line) や書簡セクション番号などに用いる。Text と Line の双方に付与されうる。"@ja ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( hmkp:Text hmktei:Line ) ] ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#att.global.n> .

hmktei:sic a owl:DatatypeProperty ;
    rdfs:label "sic (original reading)"@en , "sic (元の読み)"@ja ;
    rdfs:comment "Choice アノテーションにおいて、本文には corr を採用した際に記録される元の (誤った) 読み。"@ja ;
    rdfs:domain hmktei:Choice ;
    rdfs:range xsd:string ;
    rdfs:seeAlso <http://www.tei-c.org/ns/1.0#sic> .
